HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Order email delivery
# Leave MAIL_ENABLED=false while SMTP credentials are not ready. Orders will be
# saved in Strapi and email delivery will be skipped.
#
# Yandex SMTP example:
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=mailbox@yandex.com
# SMTP_PASS=application-password
# MAIL_FROM=mailbox@yandex.com
# MAIL_TO=manager@example.com
MAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FAMILY=4
SMTP_CONNECTION_TIMEOUT_MS=30000
SMTP_GREETING_TIMEOUT_MS=30000
SMTP_SOCKET_TIMEOUT_MS=45000
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=
MAIL_BCC=
ORDER_MAIL_SUBJECT_PREFIX="Leppa & WenSton"
