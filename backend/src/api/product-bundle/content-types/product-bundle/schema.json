{
  "kind": "collectionType",
  "collectionName": "product_bundles",
  "info": {
    "singularName": "product-bundle",
    "pluralName": "product-bundles",
    "displayName": "Выгодные комплекты",
    "description": "Комплекты товаров, которые показываются в карточках выбранных товаров"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "default": "Выгодный комплект"
    },
    "enabled": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "discountPercent": {
      "type": "decimal",
      "required": true,
      "min": 0,
      "max": 100,
      "default": 6
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product"
    }
  }
}
