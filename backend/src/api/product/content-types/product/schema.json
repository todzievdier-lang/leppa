{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "required": true,
      "minLength": 2
    },
    "sku": {
      "type": "string"
    },
    "baseSku": {
      "type": "string"
    },
    "color": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::color.color"
    },
    "name": {
      "type": "string",
      "required": true
    },
    "brand": {
      "type": "string"
    },
    "price": {
      "type": "decimal",
      "required": false
    },
    "description": {
      "type": "blocks"
    },
    "specifications": {
      "type": "component",
      "repeatable": true,
      "component": "product.specification"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "videos": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "attributes": {
      "type": "json",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        },
        "content-type-builder": {
          "visible": false
        }
      }
    },
    "bundles": {
      "type": "json",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        },
        "content-type-builder": {
          "visible": false
        }
      }
    },
    "inStock": {
      "type": "boolean"
    },
    "category": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::category.category"
    }
  }
}
